{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadRawBucketObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::nexus-v2-raw-prod/raw/*"
    },
    {
      "Sid": "ListRawBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::nexus-v2-raw-prod",
      "Condition": {
        "StringLike": {
          "s3:prefix": ["raw/*"]
        }
      }
    },
    {
      "Sid": "ReceiveAndDeleteSqsMessages",
      "Effect": "Allow",
      "Action": [
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:ChangeMessageVisibility",
        "sqs:GetQueueAttributes"
      ],
      "Resource": [
        "arn:aws:sqs:ap-southeast-1:123456789012:nexus-v2-s3-events-prod"
      ]
    },
    {
      "Sid": "ReadSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "ssm:GetParameter",
        "ssm:GetParameters"
      ],
      "Resource": [
        "arn:aws:secretsmanager:ap-southeast-1:123456789012:secret:nexus-v2/*",
        "arn:aws:ssm:ap-southeast-1:123456789012:parameter/nexus-v2/*"
      ]
    },
    {
      "Sid": "UseKmsForRawBucketAndSecrets",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt",
        "kms:Encrypt",
        "kms:GenerateDataKey"
      ],
      "Resource": "arn:aws:kms:ap-southeast-1:123456789012:key/REPLACE_WITH_KMS_KEY_ID"
    },
    {
      "Sid": "WriteCloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:ap-southeast-1:123456789012:log-group:/nexus-v2/*"
    }
  ]
}
